# hermes-optx-api configuration
# Copy to .env and customize

# Hermes Agent gateway URL
HERMES_AGENT_URL=http://localhost:8642

# Path to Hermes config directory
HERMES_HOME=~/.hermes

# Bridge API settings
OPTX_API_HOST=0.0.0.0
OPTX_API_PORT=8643

# Optional API key for authentication (subscribers bypass MPP payment)
# API_KEY=your-secret-key

# Memory backend: holographic | sqlite | spacetimedb
MEMORY_BACKEND=holographic

# For SpacetimeDB backend (edge DB on Jetson):
# MEMORY_BACKEND=spacetimedb
# MEMORY_DB_URL=http://100.85.183.16:3000
# SPACETIMEDB_DB=optx-cortex

# -- MPP (Machine Payments Protocol) ------------------------------------------
# Enable pay-per-request via Tempo stablecoins (pathUSD)
# Clients pay with: tempo request, mppx, or any MPP-compatible wallet
# Docs: https://mpp.dev/quickstart/server

# MPP_ENABLED=true
# MPP_RECIPIENT=0xYourTempoWalletAddress
# MPP_AMOUNT=0.10          # pathUSD per request (default: 0.10 = $0.10)
# MPP_NETWORK=testnet        # testnet | mainnet
# MPP_FEE_PAYER_KEY=0x...    # optional: sponsor gas so clients pay zero fees
# MPP_SECRET_KEY=generate-with-python-secrets.token_urlsafe(32)
