# hermes-optx-api configuration
# Copy to .env and customize

# Hermes Agent gateway URL
HERMES_AGENT_URL=http://localhost:8642

# Path to Hermes config directory
HERMES_HOME=~/.hermes

# Bridge API settings
OPTX_API_HOST=0.0.0.0
OPTX_API_PORT=8643

# Optional API key for authentication
# API_KEY=your-secret-key

# Memory backend: holographic | sqlite | spacetimedb | custom
MEMORY_BACKEND=holographic

# For SpacetimeDB backend:
# MEMORY_DB_URL=http://your-spacetimedb-host:3000
# SPACETIMEDB_DB=your-database-name
